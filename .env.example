# Database
DB_NAME=sebook
DB_USER=appuser
DB_USERNAME=appuser
DB_PASSWORD=change_me
POSTGRES_PASSWORD=change_me_root
POSTGRES_REPLICATION_USER=replicator
POSTGRES_REPLICATION_PASSWORD=change_me_replication
POSTGRES_IMAGE=pgvector/pgvector:pg15

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=change_me_redis

# Runtime
SPRING_PROFILES_ACTIVE=prod
APP_AUTH_COOKIE_SECURE=true
APP_AUTH_COOKIE_SAME_SITE=None
APP_CORS_ALLOWED_ORIGINS=https://your-frontend-domain.com

# Docker image
DOCKERHUB_USERNAME=your-dockerhub-username
APP_VERSION=latest

# Grafana
GRAFANA_USER=admin
GRAFANA_PASSWORD=change_me_admin

# JWT
JWT_SECRET_KEY=your_jwt_secret_key_here
JWT_PRIVATE_KEY=file:./config/keys/private_key.pem
JWT_PUBLIC_KEY=file:./config/keys/public_key.pem
JWT_OTP_SECRET=your_otp_secret_here

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Email (Brevo / SMTP)
BREVO_API_KEY=your_brevo_api_key
BREVO_SENDER_NAME=SEBook Store
BREVO_SENDER_EMAIL=your_sender_email@example.com
BREVO_API_URL=https://api.brevo.com/v3/smtp/email
MAIL_USERNAME=your_smtp_username
MAIL_PASSWORD=your_smtp_password

# VNPAY
VNPAY_TMNCODE=your_vnpay_tmn_code
VNPAY_HASHSECRET=your_vnpay_hash_secret
VNPAY_RETURN_URL=https://your-backend-domain.com/api/payment/vnpay-return

# Frontend URL (for CORS, redirect, links)
FRONTEND_URL=https://your-frontend-domain.com

# AI
GEMINI_API_KEY=your_gemini_api_key
COHERE_API_KEY=your_cohere_api_key
COHERE_EMBEDDING_MODEL=embed-multilingual-v3.0
